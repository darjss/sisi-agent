{
	"name": "extension",
	"version": "0.0.0",
	"private": true,
	"description": "manifest.json description",
	"type": "module",
	"scripts": {
		"dev": "wxt --port 5555",
		"dev:firefox": "wxt -b firefox --port 5555",
		"build": "wxt build",
		"build:firefox": "wxt build -b firefox",
		"zip": "wxt zip",
		"zip:firefox": "wxt zip -b firefox",
		"compile": "tsc --noEmit",
		"postinstall": "wxt prepare"
	},
	"dependencies": {
		"@sisi-agent/ui": "workspace:*",
		"react": "^19.2.3",
		"react-dom": "^19.2.3",
		"shadcn": "^3.6.2",
		"tw-animate-css": "^1.2.5"
	},
	"devDependencies": {
		"@tailwindcss/vite": "^4.0.15",
		"@types/react": "^19.2.7",
		"@types/react-dom": "^19.2.3",
		"@wxt-dev/module-react": "^1.1.5",
		"tailwindcss": "^4.0.15",
		"typescript": "^5.9.3",
		"wxt": "^0.20.6"
	}
}
