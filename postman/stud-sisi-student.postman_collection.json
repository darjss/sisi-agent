    {
      "name": "API Login + Token Bootstrap (Automated)",
      "description": "Programmatic auth flow: fetch CSRF token, submit login form with double-MD5 password, obtain OAuth access token from redirect fragment, call /resource/Me to extract sih/priv_hash and bootstrap vars.",
      "item": [
        {
          "name": "1) Login Page (Fetch CSRF)",
          "request": {
            "method": "GET",
            "url": "{{auth_base}}/oauth2/account/login?ReturnUrl=/oauth2/OAuth/Authorize?client_id={{clientId}}%26redirect_uri={{redirectUri}}%26state={{state}}%26scope={{scope}}%26response_type={{responseType}}",
            "description": "Gets anti-forgery token (__RequestVerificationToken)."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const html = pm.response.text();",
                  "const m = html.match(/name=\"__RequestVerificationToken\"\\s+type=\"hidden\"\\s+value=\"([^\"]+)\"/i);",
                  "if (m && m[1]) { pm.collectionVariables.set('__RequestVerificationToken', m[1]); }",
                  "const returnUrl = '/oauth2/OAuth/Authorize?client_id=' + encodeURIComponent(pm.collectionVariables.get('clientId')) + '&redirect_uri=' + encodeURIComponent(pm.collectionVariables.get('redirectUri')) + '&state=' + encodeURIComponent(pm.collectionVariables.get('state')) + '&scope=' + encodeURIComponent(pm.collectionVariables.get('scope')) + '&response_type=' + encodeURIComponent(pm.collectionVariables.get('responseType'));",
                  "pm.collectionVariables.set('returnUrl', returnUrl);",
                  "pm.test('CSRF token captured', function(){ pm.expect(pm.collectionVariables.get('__RequestVerificationToken')).to.be.ok; });"
                ]
              }
            }
          ]
        },
        {
          "name": "2) Login Submit (Form POST)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "__RequestVerificationToken",
                  "value": "{{__RequestVerificationToken}}",
                  "type": "text"
                },
                {
                  "key": "username",
                  "value": "{{username}}",
                  "type": "text"
                },
                {
                  "key": "password",
                  "value": "{{password}}",
                  "type": "text"
                },
                {
                  "key": "passwordMD5",
                  "value": "{{passwordMD5}}",
                  "type": "text"
                },
                {
                  "key": "submit.Signin",
                  "value": "Нэвтрэх",
                  "type": "text"
                }
              ]
            },
            "url": "{{auth_base}}/oauth2/account/login?ReturnUrl={{returnUrl}}",
            "description": "Submits credentials. Requires passwordMD5 = md5(md5(password))."
          },
          "protocolProfileBehavior": {
            "followRedirects": false
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const pwd = pm.collectionVariables.get('password') || '';",
                  "const md5once = CryptoJS.MD5(pwd).toString().toLowerCase();",
                  "const md5twice = CryptoJS.MD5(md5once).toString().toLowerCase();",
                  "pm.collectionVariables.set('passwordMD5', md5twice);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login returns redirect', function(){ pm.expect(pm.response.code).to.be.oneOf([302,303]); });",
                  "const loc = pm.response.headers.get('Location') || pm.response.headers.get('location') || '';",
                  "if (loc) pm.collectionVariables.set('oauthAuthorizeUrl', loc);",
                  "pm.test('Captured authorize redirect location', function(){ pm.expect(pm.collectionVariables.get('oauthAuthorizeUrl')).to.be.ok; });"
                ]
              }
            }
          ]
        },
        {
          "name": "3) OAuth Authorize (Capture access token)",
          "request": {
            "method": "GET",
            "url": "{{oauthAuthorizeUrl}}",
            "description": "Uses login session cookies. Captures access token from redirect fragment in Location header."
          },
          "protocolProfileBehavior": {
            "followRedirects": false
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const loc = pm.response.headers.get('Location') || pm.response.headers.get('location') || '';",
                  "if (loc) pm.collectionVariables.set('oauthRedirectLocation', loc);",
                  "const hash = loc.includes('#') ? loc.split('#')[1] : '';",
                  "const params = new URLSearchParams(hash);",
                  "const accessToken = params.get('access_token');",
                  "if (accessToken) {",
                  "  pm.collectionVariables.set('token', accessToken);",
                  "  pm.collectionVariables.set('authToken', accessToken);",
                  "  pm.collectionVariables.set('tokenType', params.get('token_type') || 'Bearer');",
                  "  pm.collectionVariables.set('expiresInSeconds', params.get('expires_in') || '');",
                  "}",
                  "pm.test('Access token captured from redirect fragment', function(){ pm.expect(pm.collectionVariables.get('token')).to.be.ok; });"
                ]
              }
            }
          ]
        },
        {
          "name": "4) Resource Me -> Extract SIH",
          "request": {
            "method": "GET",
            "url": "{{auth_base}}/resource/Me",
            "description": "Requires Bearer token. Extracts priv_hash as sih and other bootstrap vars."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const arr = pm.response.json();",
                  "if (Array.isArray(arr)) {",
                  "  const getVal = (k) => { const x = arr.find(i => String(i.Type).toLowerCase() === k.toLowerCase()); return x ? x.Value : ''; };",
                  "  const sih = getVal('priv_hash');",
                  "  if (sih) pm.collectionVariables.set('sih', sih);",
                  "  const unit = getVal('unit'); if (unit) pm.collectionVariables.set('unit', unit);",
                  "  const sessionid = getVal('sessionid'); if (sessionid) pm.collectionVariables.set('session', sessionid);",
                  "  const pub = getVal('pub_hash') || getVal('public_hash'); if (pub) pm.collectionVariables.set('pub_hash', pub);",
                  "}",
                  "pm.test('sih extracted from /resource/Me', function(){ pm.expect(pm.collectionVariables.get('sih')).to.be.ok; });"
                ]
              }
            }
          ]
        },
        {
          "name": "5) Verify Main Info (stud-api direct)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
